# --- Required ---
# MongoDB connection string. On Railway, add a "MongoDB" database plugin
# and it will provide this as MONGO_URL (or MONGO_PUBLIC_URL/MONGO_PRIVATE_URL —
# copy the value into MONGO_URL for this service).
MONGO_URL=mongodb://localhost:27017

# Database name to use inside the Mongo cluster above.
DB_NAME=wakawaka

# Secret used to sign JWTs. Generate a strong random value, e.g.:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret

# --- Optional (sensible defaults exist in code) ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Paystack secret key. Leave unset (or keep the sk_test_placeholder prefix)
# to run in mock-payment mode — useful for demos before you have live keys.
PAYSTACK_SECRET_KEY=sk_test_placeholder

# Platform commission taken from each delivery fare, as a percentage.
PLATFORM_FEE_PERCENT=15
